{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "eslint.validate": ["vue", "javascript", "typescript"],
  "eslint.workingDirectories": [{ "pattern": "packages/*" }, { "pattern": "examples/*" }],
  "eslint.run": "onType",
  "eslint.quiet": false,
  "eslint.lintTask.enable": true,
  "stylelint.enable": true,
  "stylelint.run": "onType",
  "stylelint.validate": ["css", "scss", "sass", "postcss", "vue", "html"],
  "markdownlint.run": "onType",
  "json.validate.enable": true,
  "yaml.validate": true,
  "htmlhint.enable": true,
  "js/ts.tsserver.maxMemory": 4096,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "vue.format.enable": false
}
