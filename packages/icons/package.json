{
  "name": "@codemonster-ru/vueforge-icons",
  "version": "1.3.1",
  "description": "Open source vue icon library.",
  "keywords": [
    "vue",
    "vue3",
    "icons",
    "icon-library",
    "svg-icons",
    "design-system"
  ],
  "homepage": "https://github.com/codemonster-ru/vueforge/tree/main/packages/icons#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codemonster-ru/vueforge.git",
    "directory": "packages/icons"
  },
  "bugs": {
    "url": "https://github.com/codemonster-ru/vueforge/issues"
  },
  "author": "Kirill Kolesnikov",
  "license": "MIT",
  "main": "./dist/index.ts.umd.js",
  "module": "./dist/index.ts.mjs",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/index.ts.mjs"
      },
      "require": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/index.ts.umd.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite dev --force --mode development",
    "create-icon": "node ./scripts/create-icon.mjs",
    "generate": "node ./scripts/generate-icons.mjs",
    "validate-icons": "node ./scripts/generate-icons.mjs --validate-only",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "build": "npm run generate && vite build --mode production",
    "build:showcase": "vite build --config vite.showcase.config.mts",
    "typecheck": "vue-tsc --noEmit",
    "render": "node ./test/render-consumer.mjs",
    "smoke": "npm run build && tsc -p tsconfig.smoke.json",
    "release": "npm run build && npm run render && npm audit signatures && npm publish"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^20.14.10",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/server-renderer": "^3.5.12",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.3.2",
    "sass": "^1.77.8",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.0.11",
    "vite-plugin-dts": "^4.5.0",
    "vite-plugin-lib-inject-css": "^2.1.1",
    "vue": "^3.5.12",
    "vue-eslint-parser": "^10.1.1",
    "vue-tsc": "^2.0.21"
  }
}
