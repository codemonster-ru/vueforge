{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "types": ["vite/client", "node"],
        "allowJs": false,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "jsx": "preserve",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["./src", "index.d.ts"],
    "exclude": ["node_modules"]
}
