{
  "name": "@codemonster-ru/vueforge-codeblock",
  "version": "3.6.1",
  "description": "Standalone Vue 3 code block component for the VueForge ecosystem with syntax highlighting and light/dark theming.",
  "license": "MIT",
  "author": "Kirill Kolesnikov",
  "keywords": [
    "vue",
    "vue3",
    "code-block",
    "syntax-highlighting",
    "code",
    "documentation",
    "vueforge"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codemonster-ru/vueforge.git",
    "directory": "packages/codeblock"
  },
  "homepage": "https://github.com/codemonster-ru/vueforge/tree/main/packages/codeblock#readme",
  "bugs": {
    "url": "https://github.com/codemonster-ru/vueforge/issues"
  },
  "type": "module",
  "main": "./dist/view.cjs",
  "module": "./dist/view.js",
  "types": "./dist/view.d.ts",
  "style": "./dist/view.css",
  "sideEffects": [
    "**/*.css",
    "dist/auto/*.js"
  ],
  "exports": {
    "./view": {
      "import": {
        "types": "./dist/view.d.ts",
        "default": "./dist/auto/view.js"
      },
      "require": {
        "types": "./dist/view.d.ts",
        "default": "./dist/view.cjs"
      }
    },
    "./highlight": {
      "import": {
        "types": "./dist/highlight.d.ts",
        "default": "./dist/highlight.js"
      },
      "require": {
        "types": "./dist/highlight.d.ts",
        "default": "./dist/highlight.cjs"
      }
    },
    "./style.css": "./dist/view.css",
    "./tokens.css": "./dist/tokens.css",
    "./codeblock.css": "./dist/codeblock.css",
    "./critical.css": "./dist/critical.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "check": "npm run lint && npm run typecheck && npm run test",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "lint": "eslint .",
    "prepack": "npm run build",
    "typecheck": "vue-tsc --noEmit",
    "smoke:css-export": "node ./scripts/smoke-css-export.mjs",
    "smoke:consumer-auto-css": "node ./scripts/smoke-consumer-auto-css.mjs",
    "test": "npm run smoke:css-export && npm run smoke:consumer-auto-css && vitest run"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@codemonster-ru/vueforge-core": "file:../core",
    "@codemonster-ru/vueforge-layouts": "file:../layouts",
    "@types/node": "^24.3.1",
    "eslint": "^9.22.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "sass": "^1.77.8",
    "typescript": "^5.5.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.21",
    "vue-tsc": "^3.0.7"
  },
  "dependencies": {
    "@codemonster-ru/vueforge-icons": "^1.5.0",
    "shiki": "^4.0.2"
  }
}
