{
  "name": "@codemonster-ru/vueforge-codeblock",
  "version": "2.2.0",
  "description": "Standalone Vue code block component with syntax highlighting and light/dark theming.",
  "license": "MIT",
  "author": "Kirill Kolesnikov",
  "keywords": [
    "vue",
    "vue3",
    "code-block",
    "syntax-highlighting",
    "code",
    "documentation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codemonster-ru/vueforge.git",
    "directory": "packages/codeblock"
  },
  "homepage": "https://github.com/codemonster-ru/vueforge/tree/main/packages/codeblock#readme",
  "bugs": {
    "url": "https://github.com/codemonster-ru/vueforge/issues"
  },
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.umd.cjs"
      }
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --force",
    "build": "vite build",
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@codemonster-ru/vueforge-core": "file:../core",
    "@codemonster-ru/vueforge-layouts": "file:../layouts",
    "@types/node": "^24.3.1",
    "eslint": "^9.22.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "sass": "^1.77.8",
    "typescript": "^5.5.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.21",
    "vue-tsc": "^3.0.7"
  },
  "dependencies": {
    "@codemonster-ru/vueforge-icons": "file:../icons",
    "shiki": "^4.0.2"
  }
}
