{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@codemonster-ru/vueforge-core": ["./src/types/deps-shim.d.ts"],
      "@codemonster-ru/vueforge-core/foundation": ["./src/types/deps-shim.d.ts"],
      "@codemonster-ru/vueforge-theme": ["./src/types/deps-shim.d.ts"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["src/**/*", "env.d.ts", "index.html"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
