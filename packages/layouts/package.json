{
  "name": "@codemonster-ru/vueforge-layouts",
  "version": "1.10.0",
  "description": "Layout primitives, shell components, and responsive composables for Vue 3 applications.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/codemonster-ru/vueforge/tree/main/packages/layouts#readme",
  "bugs": {
    "url": "https://github.com/codemonster-ru/vueforge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codemonster-ru/vueforge.git",
    "directory": "packages/layouts"
  },
  "author": "Kirill Kolesnikov (https://github.com/kolesnikovKirill)",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@codemonster-ru/vueforge-core": "^1.17.2",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@codemonster-ru/vueforge-theme": "file:../theme"
  },
  "devDependencies": {
    "@codemonster-ru/vueforge-core": "file:../core",
    "@codemonster-ru/vueforge-icons": "file:../icons",
    "@eslint/js": "^9.22.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/language-core": "~3.1.8",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.26.1",
    "unplugin-dts": "^1.0.0-beta.6",
    "vite": "^6.4.2",
    "vitest": "^3.0.8",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.1.1",
    "vue-tsc": "^2.2.8"
  },
  "keywords": [
    "vue",
    "vue3",
    "layout",
    "app-shell",
    "responsive",
    "docs",
    "shell",
    "composables"
  ],
  "overrides": {
    "flatted": "3.4.2"
  }
}
