{
  "name": "@codemonster-ru/vueforge-layouts",
  "version": "1.16.0",
  "description": "Layout primitives, shell components, and responsive composables for Vue 3 applications.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/codemonster-ru/vueforge/tree/main/packages/layouts#readme",
  "bugs": {
    "url": "https://github.com/codemonster-ru/vueforge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codemonster-ru/vueforge.git",
    "directory": "packages/layouts"
  },
  "author": "Kirill Kolesnikov (https://github.com/kolesnikovKirill)",
  "sideEffects": [
    "*.css",
    "dist/auto/*.js"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./container": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/container.js"
    },
    "./stack": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/stack.js"
    },
    "./inline": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/inline.js"
    },
    "./section": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/section.js"
    },
    "./grid": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/grid.js"
    },
    "./app-shell": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/app-shell.js"
    },
    "./document-layout": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/document-layout.js"
    },
    "./auth-layout": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/auth-layout.js"
    },
    "./error-layout": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/error-layout.js"
    },
    "./setup-layout": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/setup-layout.js"
    },
    "./header-area": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/header-area.js"
    },
    "./sidebar-area": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/sidebar-area.js"
    },
    "./content-area": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/content-area.js"
    },
    "./aside-area": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/aside-area.js"
    },
    "./footer-area": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto/footer-area.js"
    },
    "./breakpoints.css": "./dist/breakpoints.css",
    "./base.css": "./dist/base.css",
    "./container.css": "./dist/container.css",
    "./stack.css": "./dist/stack.css",
    "./inline.css": "./dist/inline.css",
    "./section.css": "./dist/section.css",
    "./grid.css": "./dist/grid.css",
    "./app-shell.css": "./dist/app-shell.css",
    "./document-layout.css": "./dist/document-layout.css",
    "./auth-layout.css": "./dist/auth-layout.css",
    "./error-layout.css": "./dist/error-layout.css",
    "./setup-layout.css": "./dist/setup-layout.css",
    "./header-area.css": "./dist/header-area.css",
    "./sidebar-area.css": "./dist/sidebar-area.css",
    "./content-area.css": "./dist/content-area.css",
    "./aside-area.css": "./dist/aside-area.css",
    "./footer-area.css": "./dist/footer-area.css",
    "./tokens.css": "./dist/tokens.css",
    "./theme.css": "./dist/theme.css"
  },
  "scripts": {
    "build": "vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "format": "prettier --ignore-path ../../.prettierignore . --write",
    "format:check": "prettier --ignore-path ../../.prettierignore . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "npm run build",
    "test": "npm run check:css-contract && npm run smoke:css-export && vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "smoke:css-export": "node ./scripts/smoke-css-export.mjs",
    "check:css-contract": "node ./scripts/check-css-contract.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@codemonster-ru/vueforge-core": "^1.18.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@codemonster-ru/vueforge-theme": "^1.2.4"
  },
  "devDependencies": {
    "@codemonster-ru/vueforge-core": "file:../core",
    "@codemonster-ru/vueforge-icons": "file:../icons",
    "@eslint/js": "^9.22.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/language-core": "~3.1.8",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.26.1",
    "unplugin-dts": "^1.0.0-beta.6",
    "vite": "^6.4.2",
    "vitest": "^3.0.8",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.1.1",
    "vue-tsc": "^2.2.8"
  },
  "keywords": [
    "vue",
    "vue3",
    "layout",
    "app-shell",
    "responsive",
    "docs",
    "shell",
    "composables",
    "vueforge"
  ],
  "overrides": {
    "flatted": "3.4.2"
  }
}
