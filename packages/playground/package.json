{
  "name": "@codemonster-ru/vueforge-playground",
  "version": "2.5.0",
  "description": "Vue 3 playground UI adapter for the VueForge playground core runtime.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/codemonster-ru/vueforge/tree/main/packages/playground#readme",
  "bugs": {
    "url": "https://github.com/codemonster-ru/vueforge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codemonster-ru/vueforge.git",
    "directory": "packages/playground"
  },
  "keywords": [
    "vue",
    "vue3",
    "playground",
    "sandbox",
    "vueforge"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/auto/ui.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./style.css": "./dist/index.css",
    "./tokens.css": "./dist/tokens.css",
    "./playground.css": "./dist/playground.css",
    "./critical.css": "./dist/critical.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@codemonster-ru/vueforge-playground-core": "^1.1.0",
    "@codemonster-ru/vueforge-codeblock": "^3.6.0",
    "@codemonster-ru/vueforge-core": "^1.29.0"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.6",
    "@vitejs/plugin-vue": "^5.2.4",
    "jsdom": "^26.1.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "vue": "^3.5.20",
    "vue-tsc": "^2.2.12"
  },
  "scripts": {
    "build": "rm -rf dist && vite build && vue-tsc --emitDeclarationOnly --declaration --declarationDir dist",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "lint": "eslint .",
    "prepack": "npm run build",
    "smoke:css-export": "node ./scripts/smoke-css-export.mjs",
    "smoke:consumer-auto-css": "node ./scripts/smoke-consumer-auto-css.mjs",
    "test": "npm run smoke:css-export && npm run smoke:consumer-auto-css && vitest run --passWithNoTests",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css",
    "dist/auto/*.js"
  ]
}
