{
  "name": "@codemonster-ru/vueforge-playground",
  "version": "1.0.0",
  "description": "Vue 3 playground UI adapter for the VueForge playground core runtime.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/codemonster-ru/vueforge/tree/main/packages/playground#readme",
  "bugs": {
    "url": "https://github.com/codemonster-ru/vueforge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codemonster-ru/vueforge.git",
    "directory": "packages/playground"
  },
  "keywords": [
    "vue",
    "vue3",
    "playground",
    "sandbox",
    "vueforge"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@codemonster-ru/vueforge-playground-core": "^1.0.0",
    "@codemonster-ru/vueforge-codeblock": "^2.3.0",
    "@codemonster-ru/vueforge-core": "^1.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^6.4.2",
    "vue": "^3.5.20",
    "vue-tsc": "^2.2.12"
  },
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly --declaration --declarationDir dist",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "lint": "eslint .",
    "prepack": "npm run build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
