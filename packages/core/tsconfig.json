{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@codemonster-ru/vueforge-theme": ["../theme/src/index.ts"],
      "@codemonster-ru/vueforge-icons": ["./src/types/vueforge-icons-shim.d.ts"],
      "@/*": ["./src/*"]
    },
    "types": ["vitest/globals", "jsdom"]
  },
  "include": ["src", "vite.config.ts", "vitest.config.ts", "eslint.config.js"]
}
