    "lint": "eslint .",
    "prepack": "npm run build",
    "test": "npm run check:css-contract && npm run check:form-geometry && npm run smoke:css-export && npm run smoke:consumer-css && vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "vue-tsc --noEmit",
    "smoke:css-export": "node ./scripts/smoke-css-export.mjs",
    "smoke:consumer-css": "node ./scripts/smoke-consumer-auto-css.mjs",
