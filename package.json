{
    "name": "vueforge-workspace",
    "private": true,
    "version": "0.100.0",
    "description": "VueForge workspace.",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "vite dev --config vite.docs.config.mts --force --mode development",
        "build": "npm run build:packages && npm run build:docs",
        "build:packages": "npm run build --workspaces --if-present",
        "build:docs": "vite build --config vite.docs.config.mts --mode production",
        "lint": "node --import tsx ./node_modules/eslint/bin/eslint.js packages src tests scripts *.ts *.mts --ext .ts,.vue --config eslint.config.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "vue-tsc --noEmit -p tsconfig.json && npm run typecheck --workspaces --if-present",
        "test": "vitest run",
        "test:ssr": "vitest run tests/integration/ssr-hydration.test.ts",
        "verify:bundle-size": "node --import tsx ./scripts/verify-bundle-size.ts",
        "verify:semver": "node --import tsx ./scripts/verify-semver-checklist.ts"
    },
    "devDependencies": {
        "@codemonster-ru/vue-codeblock": "^1.0.0",
        "@types/node": "^20.14.10",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@vitejs/plugin-vue": "^5.0.5",
        "@vue/eslint-config-typescript": "^14.6.0",
        "@vue/server-renderer": "^3.4.31",
        "@vue/test-utils": "^2.4.6",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-vue": "^9.27.0",
        "jiti": "^2.4.2",
        "jsdom": "^24.0.0",
        "pinia": "^2.2.4",
        "prettier": "^3.3.2",
        "sass": "^1.77.8",
        "tsx": "^4.20.5",
        "typescript": "^5.5.3",
        "vite": "^6.0.11",
        "vite-plugin-dts": "^4.5.0",
        "vitest": "^4.0.18",
        "vue": "^3.4.31",
        "vue-tsc": "^2.0.21"
    }
}
